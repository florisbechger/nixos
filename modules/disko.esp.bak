
{ pkgs, ... }:

{

  # System disk.
  disko.devices = {
    disk = {
      disk0 = {
        #device = "/dev/vda"; # First disk on VM, use MBR
        device = "/dev/sda"; # First disk on NUC, use ESP
        type = "disk";
        content = {
          type = "gpt";
          partitions = {
            boot = {
              size = "1M";
            };
            ESP = {
              name = "ESP";
              size = "512M";
              type = "EF00";
              content = {
                type = "filesystem";
                format = "vfat";
                mountpoint = "/boot";
                mountOptions = [ "umask=0077" ]; # may fail: comment out
              };
            };
            root = {
              size = "10%";
              content = {
                type = "filesystem";
                format = "ext4";
                mountpoint = "/";
                };
              };
            data = {
              size = "90%";
              content = {
                type = "filesystem";
                format = "ext4";
                mountpoint = "/data";
                };
              };

            };
          };
        };
      };
  };
}
